# Backend environment variables — see root .env.example for full list
DATABASE_URL=postgresql+asyncpg://mexc:mexc_secret@postgres:5432/mexc_p2p
REDIS_URL=redis://redis:6379
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:9000,http://127.0.0.1:9000
P2P_DATA_SOURCE=mock
P2P_ARMY_API_KEY=
P2P_ARMY_BASE_URL=https://p2p.army/v1/api
P2P_MOCK_BASE_URL=http://mock-server:8001/v1/api
POLLING_INTERVAL_SEC=10
INACTIVE_TTL_SEC=15
OPENAI_API_KEY=sk-...
LLM_CACHE_TTL_SEC=600
LLM_MAX_CHARS=300
SCORING_WEIGHT_RATING=0.3
SCORING_WEIGHT_TRADES=0.25
SCORING_WEIGHT_SUCCESS_RATE=0.3
SCORING_WEIGHT_SPEED=0.15
INTEGRAL_WEIGHT_PRICE=0.4
