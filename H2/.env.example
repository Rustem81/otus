# ===========================================
# MEXC P2P Aggregator — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://mexc:mexc_secret@postgres:5432/mexc_p2p
POSTGRES_USER=mexc
POSTGRES_PASSWORD=mexc_secret

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Auth ---
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:9000,http://127.0.0.1:9000

# --- P2P Data Source ---
# Options: p2p_army | mock
P2P_DATA_SOURCE=mock
P2P_ARMY_API_KEY=
P2P_ARMY_BASE_URL=https://p2p.army/v1/api
P2P_MOCK_BASE_URL=http://mock-server:8001/v1/api

# --- Polling ---
POLLING_INTERVAL_SEC=10
INACTIVE_TTL_SEC=15

# --- LLM (OpenAI) ---
OPENAI_API_KEY=sk-...
LLM_CACHE_TTL_SEC=600
LLM_MAX_CHARS=300

# --- Scoring Weights ---
SCORING_WEIGHT_RATING=0.3
SCORING_WEIGHT_TRADES=0.25
SCORING_WEIGHT_SUCCESS_RATE=0.3
SCORING_WEIGHT_SPEED=0.15

# --- Integral Score Weights ---
INTEGRAL_WEIGHT_PRICE=0.4
INTEGRAL_WEIGHT_RISK=0.35
INTEGRAL_WEIGHT_PROFILE=0.25

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
